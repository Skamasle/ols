<?php
$escape = static function ($value) {
    return htmlspecialchars((string) $value, ENT_QUOTES, 'UTF-8');
};

$statusClass = static function ($type) {
    return array(
        'success' => 'skamasle-ols-alert--success',
        'warning' => 'skamasle-ols-alert--warning',
        'error' => 'skamasle-ols-alert--error',
        'info' => 'skamasle-ols-alert--info',
    )[$type] ?? 'skamasle-ols-alert--info';
};

$pillClass = static function ($isActive) {
    return $isActive ? 'skamasle-ols-pill--ok' : 'skamasle-ols-pill--muted';
};

$controlStatus = isset($this->controlStatus) && is_array($this->controlStatus)
    ? $this->controlStatus
    : array();
$engine = isset($controlStatus['engine']) && is_array($controlStatus['engine'])
    ? $controlStatus['engine']
    : array();
$listener = isset($controlStatus['listener']) && is_array($controlStatus['listener'])
    ? $controlStatus['listener']
    : array('bindAddress' => '127.0.0.1', 'port' => 'unknown', 'protocol' => 'http');
$nginxService = isset($controlStatus['nginxService']) && is_array($controlStatus['nginxService'])
    ? $controlStatus['nginxService']
    : array();
$templateStatus = isset($controlStatus['templateStatus']) && is_array($controlStatus['templateStatus'])
    ? $controlStatus['templateStatus']
    : array();
$enterpriseStatus = isset($controlStatus['enterpriseStatus']) && is_array($controlStatus['enterpriseStatus'])
    ? $controlStatus['enterpriseStatus']
    : array();
$engineInstalled = !empty($engine['installed']);
$templateInstalled = !empty($templateStatus['installed']);
$templateExists = !empty($templateStatus['customTemplateExists']);
$templateBackupRequired = !empty($templateStatus['backupRequired']);
$templateRefreshRequired = !empty($templateStatus['refreshRequired']);
$templateSourceHash = isset($templateStatus['sourceHash']) ? (string) $templateStatus['sourceHash'] : '';
$templateTargetHash = isset($templateStatus['targetHash']) ? (string) $templateStatus['targetHash'] : '';
$templateHashesMatch = '' !== $templateSourceHash
    && $templateSourceHash === $templateTargetHash;
$enterpriseInstalled = !empty($enterpriseStatus['installed']);
$nginxActive = !empty($nginxService['active']);
$moduleVersion = isset($this->moduleVersion) ? (string) $this->moduleVersion : 'unknown';
$projectUrl = isset($this->projectUrl) ? (string) $this->projectUrl : '#';
$gitUrl = isset($this->gitUrl) ? (string) $this->gitUrl : '#';
$domainSearch = isset($this->domainSearch) ? (string) $this->domainSearch : '';
$domainPage = isset($this->domainPage) ? max(1, (int) $this->domainPage) : 1;
$domainPageSize = isset($this->domainPageSize) ? max(1, (int) $this->domainPageSize) : 25;
$installModeDefault = isset($this->installModeDefault) ? (string) $this->installModeDefault : 'recommended-bootstrap';
$installModeOptions = isset($this->installModeOptions) && is_array($this->installModeOptions)
    ? $this->installModeOptions
    : array();
$customRepoUrlDefault = isset($this->customRepoUrlDefault)
    ? (string) $this->customRepoUrlDefault
    : '';
$indexUrl = pm_Context::getBaseUrl() . 'index.php/index/index';
$buildDomainUrl = static function (array $params) use ($indexUrl) {
    $filtered = array();
    foreach ($params as $key => $value) {
        if (null === $value || '' === (string) $value) {
            continue;
        }
        $filtered[] = rawurlencode((string) $key) . '=' . rawurlencode((string) $value);
    }
    return $indexUrl . (empty($filtered) ? '' : ('?' . implode('&', $filtered)));
};
